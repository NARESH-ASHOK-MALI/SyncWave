<Window x:Class="SyncWave.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SyncWave.ViewModels"
        xmlns:utils="clr-namespace:SyncWave.Utils"
        Title="SyncWave — One Sound. Many Devices." 
        Height="720" Width="1100" MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#121220" Foreground="#E0E0E0"
        FontFamily="Segoe UI Variable, Segoe UI"
        Icon="/Assets/logo.png">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <!-- ───── Color Palette (refined) ───── -->
        <Color x:Key="BgPrimary">#121220</Color>
        <Color x:Key="BgSecondary">#1A1A32</Color>
        <Color x:Key="BgCard">#1E1E38</Color>
        <Color x:Key="BgCardHover">#252548</Color>
        <Color x:Key="AccentCyan">#00E5FF</Color>
        <Color x:Key="AccentPurple">#7C4DFF</Color>
        <Color x:Key="AccentGreen">#00E676</Color>
        <Color x:Key="AccentRed">#FF5252</Color>
        <Color x:Key="TextPrimary">#E8E8F0</Color>
        <Color x:Key="TextSecondary">#8090A8</Color>
        <Color x:Key="BorderSubtle">#2A2A50</Color>

        <SolidColorBrush x:Key="BgPrimaryBrush" Color="{StaticResource BgPrimary}" />
        <SolidColorBrush x:Key="BgSecondaryBrush" Color="{StaticResource BgSecondary}" />
        <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}" />
        <SolidColorBrush x:Key="AccentCyanBrush" Color="{StaticResource AccentCyan}" />
        <SolidColorBrush x:Key="AccentPurpleBrush" Color="{StaticResource AccentPurple}" />
        <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreen}" />
        <SolidColorBrush x:Key="AccentRedBrush" Color="{StaticResource AccentRed}" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
        <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtle}" />

        <!-- ───── Converters ───── -->
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <utils:StringToVisibilityConverter x:Key="StringToVisConverter" />
        <utils:LevelToWidthConverter x:Key="LevelToWidthConverter" />

        <!-- ═══════ CUSTOM SLIDER TEMPLATE ═══════ -->
        <Style x:Key="ModernSlider" TargetType="Slider">
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="500" />
            <Setter Property="IsSnapToTickEnabled" Value="True" />
            <Setter Property="TickFrequency" Value="1" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <!-- Track background -->
                            <Border x:Name="TrackBg" Height="4" CornerRadius="2"
                                    Background="#1A1A30" VerticalAlignment="Center" />
                            <!-- Filled portion -->
                            <Canvas ClipToBounds="True" VerticalAlignment="Center">
                                <Border x:Name="TrackFill" Height="4" CornerRadius="2"
                                        VerticalAlignment="Center"
                                        Canvas.Left="0" Canvas.Top="0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="{StaticResource AccentCyan}" Offset="0" />
                                            <GradientStop Color="{StaticResource AccentPurple}" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Canvas>
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.Thumb>
                                    <Thumb Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid>
                                                    <!-- Glow behind thumb -->
                                                    <Ellipse Width="20" Height="20" Opacity="0.3">
                                                        <Ellipse.Fill>
                                                            <RadialGradientBrush>
                                                                <GradientStop Color="{StaticResource AccentCyan}" Offset="0" />
                                                                <GradientStop Color="Transparent" Offset="1" />
                                                            </RadialGradientBrush>
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                    <!-- Thumb circle -->
                                                    <Ellipse x:Name="ThumbCircle" Width="14" Height="14"
                                                             Fill="{StaticResource AccentCyanBrush}"
                                                             Stroke="#121220" StrokeThickness="2">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect BlurRadius="6" ShadowDepth="0"
                                                                              Color="{StaticResource AccentCyan}" Opacity="0.5" />
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbCircle" Property="Width" Value="16" />
                                                        <Setter TargetName="ThumbCircle" Property="Height" Value="16" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Volume slider variant (purple accent) -->
        <Style x:Key="VolumeSlider" TargetType="Slider" BasedOn="{StaticResource ModernSlider}">
            <Setter Property="Maximum" Value="200" />
        </Style>

        <!-- ═══════ CUSTOM CHECKBOX (Toggle Switch) ═══════ -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Border x:Name="SwitchBg" Width="36" Height="20" CornerRadius="10"
                                    Background="#2A2A50" BorderThickness="0" Cursor="Hand">
                                <Ellipse x:Name="SwitchDot" Width="14" Height="14"
                                         Fill="#606080" HorizontalAlignment="Left" Margin="3,0,0,0">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="4" ShadowDepth="1"
                                                          Color="Black" Opacity="0.3" />
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchBg" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="{StaticResource AccentCyan}" Offset="0" />
                                            <GradientStop Color="{StaticResource AccentPurple}" Offset="1" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="SwitchDot" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="SwitchDot" Property="Margin" Value="0,0,3,0" />
                                <Setter TargetName="SwitchDot" Property="Fill" Value="White" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SwitchBg" Property="Opacity" Value="0.9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════ BUTTON STYLE (with hover animation) ═══════ -->
        <Style x:Key="SyncButton" TargetType="Button">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="24,12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}"
                                BorderThickness="0" RenderTransformOrigin="0.5,0.5">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="2"
                                                  Opacity="0.25" Color="Black" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9" />
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.03" ScaleY="1.03" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.35" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════ CARD BORDER (glassmorphism + hover) ═══════ -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1E1E38" Offset="0" />
                        <GradientStop Color="#1A1A35" Offset="0.5" />
                        <GradientStop Color="#1C1C3A" Offset="1" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#2A2A50" Offset="0" />
                        <GradientStop Color="#1A1A3A" Offset="1" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.25" Color="#0A0A1A" />
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Device card item style (hover effect) -->
        <Style x:Key="DeviceCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="Background" Value="#141428" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#1E1E40" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A1A35" />
                    <Setter Property="BorderBrush" Value="#2E2E55" />
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.005" ScaleY="1.005" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ═══════ STATUS PULSE ANIMATION ═══════ -->
        <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="StatusPulse"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0.3" Duration="0:0:1.2"
                             AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

    </Window.Resources>

    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══════════ HEADER ═══════════ -->
        <Border Grid.ColumnSpan="2" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Logo / Title -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Assets/logo.png" Width="36" Height="36" 
                           Margin="0,0,12,0" VerticalAlignment="Center" 
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <StackPanel>
                        <TextBlock FontSize="26" FontWeight="Bold" VerticalAlignment="Center">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="{StaticResource AccentCyan}" Offset="0" />
                                    <GradientStop Color="{StaticResource AccentPurple}" Offset="1" />
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                            SyncWave
                        </TextBlock>
                        <TextBlock Text="One Sound. Many Devices." 
                                   Foreground="{StaticResource TextSecondaryBrush}" 
                                   FontSize="11" FontStyle="Italic" Margin="0,-2,0,0" Opacity="0.7" />
                    </StackPanel>
                </StackPanel>

                <!-- Status Badge -->
                <Border Grid.Column="2" CornerRadius="20" Padding="18,8" VerticalAlignment="Center"
                        Background="#0D0D1A" BorderThickness="1" BorderBrush="{StaticResource BorderSubtleBrush}">
                    <StackPanel Orientation="Horizontal">
                        <Grid>
                            <!-- Pulse glow (behind dot) -->
                            <Ellipse x:Name="StatusPulse" Width="16" Height="16"
                                     Margin="0,0,8,0" VerticalAlignment="Center" Opacity="0.3"
                                     Fill="{Binding StatusBrush}" />
                            <!-- Status dot -->
                            <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center"
                                     Fill="{Binding StatusBrush}" />
                        </Grid>
                        <TextBlock Text="{Binding PlaybackStatus}" FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════ LEFT PANEL — Device Selection ═══════════ -->
        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardBorder}">
            <DockPanel>
                <!-- Panel Header -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                    <TextBlock Text="🎧  Audio Devices" FontSize="17" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentCyanBrush}" />
                    <TextBlock Text="Select devices, then click Start Sync" 
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" 
                               Margin="0,4,0,0" Opacity="0.8" />
                    <Button Content="↻ Refresh" Command="{Binding RefreshDevicesCommand}"
                            HorizontalAlignment="Left" Margin="0,10,0,0"
                            Background="#252545" Style="{StaticResource SyncButton}"
                            Padding="14,7" FontSize="12" />
                </StackPanel>

                <!-- Device List -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Devices}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource DeviceCard}">
                                    <StackPanel>
                                        <!-- Device name + toggle row -->
                                        <DockPanel>
                                            <CheckBox DockPanel.Dock="Left" IsChecked="{Binding IsSelected}"
                                                      VerticalAlignment="Center" Margin="0,0,10,0"
                                                      Style="{StaticResource ToggleSwitch}" />
                                            <Border DockPanel.Dock="Right" CornerRadius="6" Padding="8,3"
                                                    VerticalAlignment="Center">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#1A2545" Offset="0" />
                                                        <GradientStop Color="#1A1A3A" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <TextBlock Text="{Binding DeviceType}" FontSize="11"
                                                           Foreground="{StaticResource AccentCyanBrush}" 
                                                           FontWeight="Medium" />
                                            </Border>
                                            <TextBlock Text="{Binding FriendlyName}" FontSize="14"
                                                       FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                        </DockPanel>

                                        <!-- Status row -->
                                        <DockPanel Margin="48,5,0,0">
                                            <TextBlock FontSize="11" VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextSecondaryBrush}">
                                                <Run Text="Latency:" />
                                                <Run Text="{Binding MeasuredLatency, StringFormat='{}{0:F0}ms', Mode=OneWay}" 
                                                     Foreground="{StaticResource AccentCyanBrush}" />
                                                <Run Text="  ·  " />
                                                <Run Text="{Binding StatusText, Mode=OneWay}" />
                                            </TextBlock>
                                        </DockPanel>

                                        <!-- Controls (visible when selected) -->
                                        <StackPanel Margin="48,8,0,0" 
                                                    Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}">
                                            
                                            <!-- Volume slider -->
                                            <DockPanel Margin="0,0,0,6">
                                                <TextBlock DockPanel.Dock="Left" Text="🔊" FontSize="13"
                                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                                <TextBlock DockPanel.Dock="Right" FontSize="12" Width="44" TextAlignment="Right"
                                                           Foreground="{StaticResource AccentPurpleBrush}" VerticalAlignment="Center"
                                                           FontWeight="Medium">
                                                    <Run Text="{Binding Volume, StringFormat='{}{0:F0}', Mode=OneWay}" />
                                                    <Run Text="%" />
                                                </TextBlock>
                                                <Slider Value="{Binding Volume}" Margin="6,0"
                                                        Style="{StaticResource VolumeSlider}" />
                                            </DockPanel>

                                            <!-- Delay slider -->
                                            <DockPanel Margin="0,0,0,6">
                                                <TextBlock DockPanel.Dock="Left" Text="⏱" FontSize="13"
                                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                                <TextBlock DockPanel.Dock="Right" FontSize="12" Width="52"
                                                           Foreground="{StaticResource AccentCyanBrush}" VerticalAlignment="Center"
                                                           FontWeight="Medium" TextAlignment="Right">
                                                    <Run Text="{Binding ManualDelay, StringFormat='{}{0:F0}', Mode=OneWay}" />
                                                    <Run Text="ms" />
                                                </TextBlock>
                                                <Slider Value="{Binding ManualDelay}" Margin="6,0"
                                                        Style="{StaticResource ModernSlider}" />
                                            </DockPanel>

                                            <!-- Buffer health bar -->
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Left" Text="Buffer:" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                                                           Margin="0,0,8,0" />
                                                <TextBlock DockPanel.Dock="Right" FontSize="11" Margin="6,0,0,0"
                                                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center">
                                                    <Run Text="{Binding BufferHealth, StringFormat='{}{0:F0}%', Mode=OneWay}" />
                                                </TextBlock>
                                                <Border CornerRadius="3" Background="#0A0A18" Height="6">
                                                    <Border CornerRadius="3" HorizontalAlignment="Left"
                                                            Width="{Binding BufferHealth, FallbackValue=0}">
                                                        <Border.MaxWidth>
                                                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=DockPanel}" />
                                                        </Border.MaxWidth>
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                <GradientStop Color="{StaticResource AccentGreen}" Offset="0" />
                                                                <GradientStop Color="{StaticResource AccentCyan}" Offset="1" />
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                </Border>
                                            </DockPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ═══════════ RIGHT PANEL — Controls & Monitoring ═══════════ -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ── Control Buttons ── -->
            <Border Grid.Row="0" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="⚡  Playback Control" FontSize="17" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentCyanBrush}" Margin="0,0,0,4" />
                    <TextBlock Text="Play any audio on your system, then click Start Sync"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,12"
                               HorizontalAlignment="Center" Opacity="0.8" />

                    <WrapPanel HorizontalAlignment="Center">
                        <Button Content="▶  Start Sync" Command="{Binding StartSyncCommand}"
                                Style="{StaticResource SyncButton}" Margin="6">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#00C853" Offset="0" />
                                    <GradientStop Color="#00E676" Offset="1" />
                                </LinearGradientBrush>
                            </Button.Background>
                        </Button>
                        <Button Content="⏹  Stop Sync" Command="{Binding StopSyncCommand}"
                                Style="{StaticResource SyncButton}" Margin="6">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#D50000" Offset="0" />
                                    <GradientStop Color="#FF5252" Offset="1" />
                                </LinearGradientBrush>
                            </Button.Background>
                        </Button>
                    </WrapPanel>

                    <!-- Error / info message -->
                    <Border CornerRadius="8" Margin="0,10,0,0" Padding="12,8"
                            Background="#1A0A0A"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisConverter}, FallbackValue=Collapsed}">
                        <TextBlock Text="{Binding ErrorMessage}" 
                                   Foreground="{StaticResource AccentRedBrush}"
                                   FontSize="12" TextWrapping="Wrap" FontWeight="Medium"
                                   HorizontalAlignment="Center" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── Master Delay ── -->
            <Border Grid.Row="1" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="🎛  Master Delay Offset" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentPurpleBrush}" Margin="0,0,0,10" />
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Right" Width="60" TextAlignment="Right" 
                                   VerticalAlignment="Center" FontSize="13" FontWeight="Medium"
                                   Foreground="{StaticResource AccentCyanBrush}">
                            <Run Text="{Binding MasterDelayOffset, StringFormat='{}{0:F0}', Mode=OneWay}" />
                            <Run Text="ms" />
                        </TextBlock>
                        <Slider Value="{Binding MasterDelayOffset}" Maximum="500" Minimum="0"
                                Style="{StaticResource ModernSlider}" />
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- ── Waveform Visualization ── -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <TextBlock Text="📊  Waveform" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentCyanBrush}" />
                        <!-- Audio level indicator -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="Level: " FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                            <Border CornerRadius="3" Background="#0A0A18" Height="8" Width="80"
                                    VerticalAlignment="Center">
                                <Border CornerRadius="3" HorizontalAlignment="Left"
                                        Width="{Binding AudioLevel, Converter={StaticResource LevelToWidthConverter}, FallbackValue=0}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="{StaticResource AccentGreen}" Offset="0" />
                                            <GradientStop Color="#FFD740" Offset="0.7" />
                                            <GradientStop Color="{StaticResource AccentRed}" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Border>
                        </StackPanel>
                    </DockPanel>

                    <Border CornerRadius="10" Background="#0A0A18" Padding="4" ClipToBounds="True">
                        <Canvas x:Name="WaveformCanvas" SizeChanged="WaveformCanvas_SizeChanged" />
                    </Border>
                </DockPanel>
            </Border>

            <!-- ── Monitoring Stats ── -->
            <Border Grid.Row="3" Style="{StaticResource CardBorder}">
                <UniformGrid Columns="3">
                    <!-- Active Devices -->
                    <StackPanel HorizontalAlignment="Center" Margin="8,0">
                        <TextBlock Text="Active Devices" FontSize="10" 
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding ActiveDeviceCount}" FontSize="30" FontWeight="Bold"
                                   Foreground="{StaticResource AccentGreenBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                    <!-- Max Latency Diff -->
                    <StackPanel HorizontalAlignment="Center" Margin="8,0">
                        <TextBlock Text="Max Latency Diff" FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                        <TextBlock FontSize="30" FontWeight="Bold" HorizontalAlignment="Center"
                                   Foreground="{StaticResource AccentCyanBrush}">
                            <Run Text="{Binding MaxLatencyDiff, StringFormat='{}{0:F1}', Mode=OneWay}" />
                            <Run Text="ms" FontSize="14" />
                        </TextBlock>
                    </StackPanel>
                    <!-- Status -->
                    <StackPanel HorizontalAlignment="Center" Margin="8,0">
                        <TextBlock Text="Status" FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding PlaybackStatus}" FontSize="22" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="{Binding StatusBrush}" />
                    </StackPanel>
                </UniformGrid>
            </Border>
        </Grid>

        <!-- ═══════════ FOOTER ═══════════ -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Margin="0,10,0,0" Padding="10,6">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" Text="v1.1.0" FontSize="10"
                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Opacity="0.6" />
                <TextBlock FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                           Opacity="0.6">
                    <Run Text="SyncWave" FontWeight="SemiBold" />
                    <Run Text=" — System audio routed via WASAPI loopback. No kernel drivers required." />
                </TextBlock>
            </DockPanel>
        </Border>
    </Grid>
</Window>
