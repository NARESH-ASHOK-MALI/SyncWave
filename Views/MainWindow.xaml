<Window x:Class="SyncWave.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SyncWave.ViewModels"
        xmlns:utils="clr-namespace:SyncWave.Utils"
        Title="SyncWave — One Sound. Many Devices." 
        Height="720" Width="1100" MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E" Foreground="#E0E0E0"
        FontFamily="Segoe UI"
        Icon="/Assets/logo.png">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <!-- ───── Color Palette ───── -->
        <SolidColorBrush x:Key="BgPrimaryBrush" Color="#1A1A2E" />
        <SolidColorBrush x:Key="BgSecondaryBrush" Color="#16213E" />
        <SolidColorBrush x:Key="BgCardBrush" Color="#0F3460" />
        <SolidColorBrush x:Key="AccentCyanBrush" Color="#00E5FF" />
        <SolidColorBrush x:Key="AccentPurpleBrush" Color="#7C4DFF" />
        <SolidColorBrush x:Key="AccentGreenBrush" Color="#00E676" />
        <SolidColorBrush x:Key="AccentRedBrush" Color="#FF5252" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E0E0E0" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#90A4AE" />

        <!-- ───── Bool → Visibility ───── -->
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <utils:StringToVisibilityConverter x:Key="StringToVisConverter" />
        <utils:LevelToWidthConverter x:Key="LevelToWidthConverter" />

        <!-- ───── Button Style ───── -->
        <Style x:Key="SyncButton" TargetType="Button">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="24,12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.35" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ───── Card Border Style ───── -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#16213E" Offset="0" />
                        <GradientStop Color="#1A1A3E" Offset="1" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#2A2A4A" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.3" Color="Black" />
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ───── Slider Style ───── -->
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="{StaticResource AccentCyanBrush}" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="500" />
            <Setter Property="IsSnapToTickEnabled" Value="True" />
            <Setter Property="TickFrequency" Value="1" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══════════ HEADER ═══════════ -->
        <Border Grid.ColumnSpan="2" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Logo / Title -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Assets/logo.png" Width="32" Height="32" 
                           Margin="0,0,10,0" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality" />
                    <StackPanel>
                        <TextBlock FontSize="24" FontWeight="Bold" VerticalAlignment="Center">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#00E5FF" Offset="0" />
                                    <GradientStop Color="#7C4DFF" Offset="1" />
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                            SyncWave
                        </TextBlock>
                        <TextBlock Text="One Sound. Many Devices." Foreground="{StaticResource TextSecondaryBrush}" 
                                   FontSize="11" FontStyle="Italic" Margin="0,-2,0,0" />
                    </StackPanel>
                </StackPanel>

                <!-- Status Badge — uses StatusBrush (SolidColorBrush) binding -->
                <Border Grid.Column="2" CornerRadius="16" Padding="16,6" VerticalAlignment="Center"
                        Background="#0D0D1A" BorderThickness="1" BorderBrush="#2A2A4A">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center"
                                 Fill="{Binding StatusBrush}" />
                        <TextBlock Text="{Binding PlaybackStatus}" FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════ LEFT PANEL — Device Selection ═══════════ -->
        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardBorder}">
            <DockPanel>
                <!-- Panel Header -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                    <TextBlock Text="🎧  Audio Devices" FontSize="17" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentCyanBrush}" />
                    <TextBlock Text="Select one or more devices, then click Start Sync" 
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,4,0,0" />
                    <Button Content="↻ Refresh" Command="{Binding RefreshDevicesCommand}"
                            HorizontalAlignment="Left" Margin="0,8,0,0"
                            Background="#2A2A4A" Style="{StaticResource SyncButton}"
                            Padding="12,6" FontSize="13" />
                </StackPanel>

                <!-- Device List -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Devices}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="8" Padding="12" Margin="0,4"
                                        Background="#0D1B2A" BorderThickness="1" BorderBrush="#1E3A5F">
                                    <StackPanel>
                                        <!-- Device name + checkbox row -->
                                        <DockPanel>
                                            <CheckBox DockPanel.Dock="Left" IsChecked="{Binding IsSelected}"
                                                      VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <Border DockPanel.Dock="Right" CornerRadius="4" Padding="6,2"
                                                    VerticalAlignment="Center"
                                                    Background="#1A2A4A">
                                                <TextBlock Text="{Binding DeviceType}" FontSize="12"
                                                           Foreground="{StaticResource AccentCyanBrush}" />
                                            </Border>
                                            <TextBlock Text="{Binding FriendlyName}" FontSize="14"
                                                       FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                        </DockPanel>

                                        <!-- Status row -->
                                        <DockPanel Margin="26,4,0,0">
                                            <TextBlock FontSize="12" VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextSecondaryBrush}">
                                                <Run Text="Latency:" />
                                                <Run Text="{Binding MeasuredLatency, StringFormat='{}{0:F1}ms', Mode=OneWay}" 
                                                     Foreground="{StaticResource AccentCyanBrush}" />
                                                <Run Text="  |  " />
                                                <Run Text="{Binding StatusText, Mode=OneWay}" />
                                            </TextBlock>
                                        </DockPanel>

                                        <!-- Controls (visible when selected) -->
                                        <StackPanel Margin="26,6,0,0" 
                                                    Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}">
                                            <!-- Volume slider -->
                                            <DockPanel Margin="0,0,0,4">
                                                <TextBlock DockPanel.Dock="Left" Text="🔊 Vol:" FontSize="12"
                                                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                                <TextBlock DockPanel.Dock="Right" FontSize="12" Width="42" TextAlignment="Right"
                                                           Foreground="{StaticResource AccentPurpleBrush}" VerticalAlignment="Center">
                                                    <Run Text="{Binding Volume, StringFormat='{}{0:F0}', Mode=OneWay}" />
                                                    <Run Text="%" />
                                                </TextBlock>
                                                <Slider Value="{Binding Volume}" Margin="8,0"
                                                        Maximum="200" Minimum="0" />
                                            </DockPanel>

                                            <!-- Delay slider -->
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Left" Text="Delay:" FontSize="12"
                                                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                                <TextBlock DockPanel.Dock="Right" FontSize="12" 
                                                           Foreground="{StaticResource AccentCyanBrush}" VerticalAlignment="Center">
                                                    <Run Text="{Binding ManualDelay, StringFormat='{}{0:F0}', Mode=OneWay}" />
                                                    <Run Text="ms" />
                                                </TextBlock>
                                                <Slider Value="{Binding ManualDelay}" Margin="8,0"
                                                        Maximum="500" Minimum="0" />
                                            </DockPanel>

                                            <!-- Buffer health bar -->
                                            <DockPanel Margin="0,4,0,0">
                                                <TextBlock DockPanel.Dock="Left" Text="Buffer:" FontSize="12"
                                                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                                                           Margin="0,0,8,0" />
                                                <TextBlock DockPanel.Dock="Right" FontSize="12" Margin="4,0,0,0"
                                                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center">
                                                    <Run Text="{Binding BufferHealth, StringFormat='{}{0:F0}%', Mode=OneWay}" />
                                                </TextBlock>
                                                <Border CornerRadius="3" Background="#0A0A1A" Height="6">
                                                    <Border CornerRadius="3" HorizontalAlignment="Left"
                                                            Width="{Binding BufferHealth, FallbackValue=0}">
                                                        <Border.MaxWidth>
                                                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=DockPanel}" />
                                                        </Border.MaxWidth>
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                <GradientStop Color="#00E676" Offset="0" />
                                                                <GradientStop Color="#00E5FF" Offset="1" />
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                </Border>
                                            </DockPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ═══════════ RIGHT PANEL — Controls & Monitoring ═══════════ -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ── Control Buttons ── -->
            <Border Grid.Row="0" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="⚡  Playback Control" FontSize="17" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentCyanBrush}" Margin="0,0,0,4" />
                    <TextBlock Text="Play any audio on your system, then click Start Sync"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10"
                               HorizontalAlignment="Center" />

                    <WrapPanel HorizontalAlignment="Center">
                        <Button Content="▶  Start Sync" Command="{Binding StartSyncCommand}"
                                Style="{StaticResource SyncButton}" Margin="6">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#00C853" Offset="0" />
                                    <GradientStop Color="#00E676" Offset="1" />
                                </LinearGradientBrush>
                            </Button.Background>
                        </Button>
                        <Button Content="⏹  Stop Sync" Command="{Binding StopSyncCommand}"
                                Style="{StaticResource SyncButton}" Margin="6">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#D50000" Offset="0" />
                                    <GradientStop Color="#FF5252" Offset="1" />
                                </LinearGradientBrush>
                            </Button.Background>
                        </Button>
                    </WrapPanel>

                    <!-- Error / info message (prominent) -->
                    <Border CornerRadius="6" Margin="0,8,0,0" Padding="10,6"
                            Background="#1A0A0A"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisConverter}, FallbackValue=Collapsed}">
                        <TextBlock Text="{Binding ErrorMessage}" 
                                   Foreground="{StaticResource AccentRedBrush}"
                                   FontSize="12" TextWrapping="Wrap" FontWeight="Medium"
                                   HorizontalAlignment="Center" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── Master Delay ── -->
            <Border Grid.Row="1" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="🎛  Master Delay Offset" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentPurpleBrush}" Margin="0,0,0,8" />
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Right" Width="60" TextAlignment="Right" 
                                   VerticalAlignment="Center" FontSize="13"
                                   Foreground="{StaticResource AccentCyanBrush}">
                            <Run Text="{Binding MasterDelayOffset, StringFormat='{}{0:F0}', Mode=OneWay}" />
                            <Run Text="ms" />
                        </TextBlock>
                        <Slider Value="{Binding MasterDelayOffset}" Maximum="500" Minimum="0" />
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- ── Waveform Visualization ── -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Text="📊  Waveform" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentCyanBrush}" />
                        <!-- Audio level indicator -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="Level: " FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                            <Border CornerRadius="3" Background="#0A0A1A" Height="8" Width="80"
                                    VerticalAlignment="Center">
                                <Border CornerRadius="3" HorizontalAlignment="Left"
                                        Width="{Binding AudioLevel, Converter={StaticResource LevelToWidthConverter}, FallbackValue=0}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00E676" Offset="0" />
                                            <GradientStop Color="#FFD740" Offset="0.7" />
                                            <GradientStop Color="#FF5252" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Border>
                        </StackPanel>
                    </DockPanel>

                    <Border CornerRadius="8" Background="#0A0A1A" Padding="4" ClipToBounds="True">
                        <Canvas x:Name="WaveformCanvas" SizeChanged="WaveformCanvas_SizeChanged" />
                    </Border>
                </DockPanel>
            </Border>

            <!-- ── Monitoring Stats ── -->
            <Border Grid.Row="3" Style="{StaticResource CardBorder}">
                <UniformGrid Columns="3">
                    <!-- Active Devices -->
                    <StackPanel HorizontalAlignment="Center" Margin="8,0">
                        <TextBlock Text="Active Devices" FontSize="10" 
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding ActiveDeviceCount}" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource AccentGreenBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                    <!-- Max Latency Diff -->
                    <StackPanel HorizontalAlignment="Center" Margin="8,0">
                        <TextBlock Text="Max Latency Diff" FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                        <TextBlock FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"
                                   Foreground="{StaticResource AccentCyanBrush}">
                            <Run Text="{Binding MaxLatencyDiff, StringFormat='{}{0:F1}', Mode=OneWay}" />
                            <Run Text="ms" FontSize="14" />
                        </TextBlock>
                    </StackPanel>
                    <!-- Status -->
                    <StackPanel HorizontalAlignment="Center" Margin="8,0">
                        <TextBlock Text="Status" FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding PlaybackStatus}" FontSize="20" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="{Binding StatusBrush}" />
                    </StackPanel>
                </UniformGrid>
            </Border>
        </Grid>

        <!-- ═══════════ FOOTER ═══════════ -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Margin="0,8,0,0" Padding="8,4">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" Text="v1.0.0" FontSize="10"
                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                <TextBlock FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center">
                    <Run Text="SyncWave" FontWeight="SemiBold" />
                    <Run Text=" — System audio routed via WASAPI loopback. No kernel drivers required." />
                </TextBlock>
            </DockPanel>
        </Border>
    </Grid>
</Window>
