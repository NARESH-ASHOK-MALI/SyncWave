<Window x:Class="SyncWave.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SyncWave.ViewModels"
        xmlns:utils="clr-namespace:SyncWave.Utils"
        Title="SyncWave — One Sound. Many Devices." 
        Height="720" Width="1100" MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Foreground="#D4D4D4"
        FontFamily="Segoe UI Variable, Segoe UI"
        Icon="/Assets/logo.png"
        ResizeMode="CanResizeWithGrip">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <!-- ───── OLED Color Palette (muted, no neon) ───── -->
        <Color x:Key="BgPrimary">#000000</Color>
        <Color x:Key="BgSecondary">#0A0A0A</Color>
        <Color x:Key="BgCard">#111111</Color>
        <Color x:Key="BgCardHover">#1A1A1A</Color>
        <Color x:Key="AccentPrimary">#B0B0B0</Color>
        <Color x:Key="AccentMuted">#808080</Color>
        <Color x:Key="AccentGreen">#5A9A5A</Color>
        <Color x:Key="AccentRed">#B05050</Color>
        <Color x:Key="AccentAmber">#A08040</Color>
        <Color x:Key="TextPrimary">#D4D4D4</Color>
        <Color x:Key="TextSecondary">#707070</Color>
        <Color x:Key="BorderSubtle">#1E1E1E</Color>

        <SolidColorBrush x:Key="BgPrimaryBrush" Color="{StaticResource BgPrimary}" />
        <SolidColorBrush x:Key="BgSecondaryBrush" Color="{StaticResource BgSecondary}" />
        <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}" />
        <SolidColorBrush x:Key="AccentPrimaryBrush" Color="{StaticResource AccentPrimary}" />
        <SolidColorBrush x:Key="AccentMutedBrush" Color="{StaticResource AccentMuted}" />
        <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreen}" />
        <SolidColorBrush x:Key="AccentRedBrush" Color="{StaticResource AccentRed}" />
        <SolidColorBrush x:Key="AccentAmberBrush" Color="{StaticResource AccentAmber}" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
        <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtle}" />

        <!-- ───── Converters ───── -->
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <utils:StringToVisibilityConverter x:Key="StringToVisConverter" />
        <utils:LevelToWidthConverter x:Key="LevelToWidthConverter" />

        <!-- ═══════ CUSTOM SLIDER TEMPLATE ═══════ -->
        <Style x:Key="ModernSlider" TargetType="Slider">
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="500" />
            <Setter Property="IsSnapToTickEnabled" Value="True" />
            <Setter Property="TickFrequency" Value="1" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <!-- Track background -->
                            <Border x:Name="TrackBg" Height="3" CornerRadius="1.5"
                                    Background="#1A1A1A" VerticalAlignment="Center" />
                            <!-- Filled portion -->
                            <Canvas ClipToBounds="True" VerticalAlignment="Center">
                                <Border x:Name="TrackFill" Height="3" CornerRadius="1.5"
                                        VerticalAlignment="Center"
                                        Canvas.Left="0" Canvas.Top="0"
                                        Background="#808080" />
                            </Canvas>
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.Thumb>
                                    <Thumb Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid>
                                                    <!-- Thumb circle -->
                                                    <Ellipse x:Name="ThumbCircle" Width="12" Height="12"
                                                             Fill="#B0B0B0"
                                                             Stroke="#000000" StrokeThickness="1.5" />
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbCircle" Property="Fill" Value="#D4D4D4" />
                                                        <Setter TargetName="ThumbCircle" Property="Width" Value="14" />
                                                        <Setter TargetName="ThumbCircle" Property="Height" Value="14" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Volume slider variant -->
        <Style x:Key="VolumeSlider" TargetType="Slider" BasedOn="{StaticResource ModernSlider}">
            <Setter Property="Maximum" Value="200" />
        </Style>

        <!-- ═══════ CUSTOM CHECKBOX (Toggle Switch) ═══════ -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Border x:Name="SwitchBg" Width="36" Height="20" CornerRadius="10"
                                    Background="#1E1E1E" BorderThickness="1" BorderBrush="#2A2A2A" Cursor="Hand">
                                <Ellipse x:Name="SwitchDot" Width="14" Height="14"
                                         Fill="#505050" HorizontalAlignment="Left" Margin="2,0,0,0" />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchBg" Property="Background" Value="#2A2A2A" />
                                <Setter TargetName="SwitchBg" Property="BorderBrush" Value="#404040" />
                                <Setter TargetName="SwitchDot" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="SwitchDot" Property="Margin" Value="0,0,2,0" />
                                <Setter TargetName="SwitchDot" Property="Fill" Value="#D4D4D4" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SwitchBg" Property="BorderBrush" Value="#404040" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════ BUTTON STYLE ═══════ -->
        <Style x:Key="SyncButton" TargetType="Button">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="#D4D4D4" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                BorderThickness="1" BorderBrush="#2A2A2A"
                                RenderTransformOrigin="0.5,0.5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#404040" />
                                <Setter TargetName="border" Property="Background" Value="#1A1A1A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.35" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════ CARD BORDER (minimal) ═══════ -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#0A0A0A" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#1A1A1A" />
        </Style>

        <!-- Device card item style -->
        <Style x:Key="DeviceCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="Background" Value="#080808" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#151515" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#111111" />
                    <Setter Property="BorderBrush" Value="#252525" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ═══════ WINDOW CONTROL BUTTON ═══════ -->
        <Style x:Key="WindowControlBtn" TargetType="Button">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="32" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#808080" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1A1A1A" />
                                <Setter Property="Foreground" Value="#D4D4D4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close button (red hover) -->
        <Style x:Key="CloseBtn" TargetType="Button" BasedOn="{StaticResource WindowControlBtn}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#B05050" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════ STATUS PULSE ANIMATION ═══════ -->
        <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="StatusPulse"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0.3" Duration="0:0:1.5"
                             AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

    </Window.Resources>

    <Border BorderThickness="1" BorderBrush="#1A1A1A" CornerRadius="14" Background="#000000" ClipToBounds="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══════════ CUSTOM TITLE BAR ═══════════ -->
        <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Logo / Title -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,8,0,8">
                <Image Source="/Assets/logo.png" Width="20" Height="20" 
                       Margin="0,0,8,0" VerticalAlignment="Center" 
                       RenderOptions.BitmapScalingMode="HighQuality" />
                <TextBlock FontSize="13" FontWeight="Medium" VerticalAlignment="Center"
                           Foreground="#808080">
                    SyncWave
                </TextBlock>
            </StackPanel>

            <!-- Status Badge (centered-ish) -->
            <Border Grid.Column="2" CornerRadius="12" Padding="12,4" VerticalAlignment="Center"
                    Margin="0,0,10,0"
                    Background="#0A0A0A" BorderThickness="1" BorderBrush="{StaticResource BorderSubtleBrush}">
                <StackPanel Orientation="Horizontal">
                    <Grid>
                        <Ellipse x:Name="StatusPulse" Width="12" Height="12"
                                 Margin="0,0,6,0" VerticalAlignment="Center" Opacity="0.3"
                                 Fill="{Binding StatusBrush}" />
                        <Ellipse Width="6" Height="6" Margin="0,0,6,0" VerticalAlignment="Center"
                                 Fill="{Binding StatusBrush}" />
                    </Grid>
                    <TextBlock Text="{Binding PlaybackStatus}" FontWeight="Medium" 
                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="11" />
                </StackPanel>
            </Border>

            <!-- Window Control Buttons -->
            <StackPanel Grid.Column="3" Orientation="Horizontal">
                <Button Content="─" Style="{StaticResource WindowControlBtn}" Click="MinimizeBtn_Click" />
                <Button Content="□" Style="{StaticResource WindowControlBtn}" Click="MaximizeBtn_Click" />
                <Button Content="✕" Style="{StaticResource CloseBtn}" Click="CloseBtn_Click" />
            </StackPanel>
        </Grid>

        <!-- ═══════════ MAIN CONTENT ═══════════ -->
        <Grid Grid.Row="1" Margin="16,8,16,16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══════════ HEADER ═══════════ -->
        <Border Grid.ColumnSpan="2" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Logo / Title -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Assets/logo.png" Width="32" Height="32" 
                           Margin="0,0,10,0" VerticalAlignment="Center" 
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <StackPanel>
                        <TextBlock FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="#D4D4D4">
                            SyncWave
                        </TextBlock>
                        <TextBlock Text="One Sound. Many Devices." 
                                   Foreground="{StaticResource TextSecondaryBrush}" 
                                   FontSize="10" Margin="0,-1,0,0" Opacity="0.8" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════ LEFT PANEL — Device Selection ═══════════ -->
        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardBorder}">
            <DockPanel>
                <!-- Panel Header -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                    <TextBlock Text="Audio Devices" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="Select devices, then click Start Sync" 
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" 
                               Margin="0,3,0,0" />
                    <Button Content="Refresh" Command="{Binding RefreshDevicesCommand}"
                            HorizontalAlignment="Left" Margin="0,10,0,0"
                            Background="#111111" Style="{StaticResource SyncButton}"
                            Padding="14,6" FontSize="11" />
                </StackPanel>

                <!-- Device List -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Devices}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource DeviceCard}">
                                    <StackPanel>
                                        <!-- Device name + toggle row -->
                                        <DockPanel>
                                            <CheckBox DockPanel.Dock="Left" IsChecked="{Binding IsSelected}"
                                                      VerticalAlignment="Center" Margin="0,0,10,0"
                                                      Style="{StaticResource ToggleSwitch}" />
                                            <Border DockPanel.Dock="Right" CornerRadius="4" Padding="7,2"
                                                    VerticalAlignment="Center" Background="#141414"
                                                    BorderThickness="1" BorderBrush="#1E1E1E">
                                                <TextBlock Text="{Binding DeviceType}" FontSize="10"
                                                           Foreground="{StaticResource TextSecondaryBrush}" 
                                                           FontWeight="Medium" />
                                            </Border>
                                            <TextBlock Text="{Binding FriendlyName}" FontSize="13"
                                                       FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                        </DockPanel>

                                        <!-- Status row -->
                                        <DockPanel Margin="48,4,0,0">
                                            <TextBlock FontSize="10" VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextSecondaryBrush}">
                                                <Run Text="Latency:" />
                                                <Run Text="{Binding MeasuredLatency, StringFormat='{}{0:F0}ms', Mode=OneWay}" 
                                                     Foreground="{StaticResource AccentPrimaryBrush}" />
                                                <Run Text="  ·  " />
                                                <Run Text="{Binding StatusText, Mode=OneWay}" />
                                            </TextBlock>
                                        </DockPanel>

                                        <!-- Controls (visible when selected) -->
                                        <StackPanel Margin="48,8,0,0" 
                                                    Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}">
                                            
                                            <!-- Volume slider -->
                                            <DockPanel Margin="0,0,0,5">
                                                <TextBlock DockPanel.Dock="Left" Text="Vol" FontSize="10"
                                                           VerticalAlignment="Center" Margin="0,0,8,0"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                                <TextBlock DockPanel.Dock="Right" FontSize="11" Width="40" TextAlignment="Right"
                                                           Foreground="{StaticResource AccentPrimaryBrush}" VerticalAlignment="Center"
                                                           FontWeight="Medium">
                                                    <Run Text="{Binding Volume, StringFormat='{}{0:F0}', Mode=OneWay}" />
                                                    <Run Text="%" />
                                                </TextBlock>
                                                <Slider Value="{Binding Volume}" Margin="6,0"
                                                        Style="{StaticResource VolumeSlider}" />
                                            </DockPanel>

                                            <!-- Delay slider -->
                                            <DockPanel Margin="0,0,0,5">
                                                <TextBlock DockPanel.Dock="Left" Text="Delay" FontSize="10"
                                                           VerticalAlignment="Center" Margin="0,0,8,0"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                                <TextBlock DockPanel.Dock="Right" FontSize="11" Width="48"
                                                           Foreground="{StaticResource AccentPrimaryBrush}" VerticalAlignment="Center"
                                                           FontWeight="Medium" TextAlignment="Right">
                                                    <Run Text="{Binding ManualDelay, StringFormat='{}{0:F0}', Mode=OneWay}" />
                                                    <Run Text="ms" />
                                                </TextBlock>
                                                <Slider Value="{Binding ManualDelay}" Margin="6,0"
                                                        Style="{StaticResource ModernSlider}" />
                                            </DockPanel>

                                            <!-- Buffer health bar -->
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Left" Text="Buffer" FontSize="10"
                                                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                                                           Margin="0,0,8,0" />
                                                <TextBlock DockPanel.Dock="Right" FontSize="10" Margin="6,0,0,0"
                                                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center">
                                                    <Run Text="{Binding BufferHealth, StringFormat='{}{0:F0}%', Mode=OneWay}" />
                                                </TextBlock>
                                                <Border CornerRadius="2" Background="#111111" Height="4">
                                                    <Border CornerRadius="2" HorizontalAlignment="Left"
                                                            Width="{Binding BufferHealth, FallbackValue=0}"
                                                            Background="#505050">
                                                        <Border.MaxWidth>
                                                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=DockPanel}" />
                                                        </Border.MaxWidth>
                                                    </Border>
                                                </Border>
                                            </DockPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ═══════════ RIGHT PANEL — Controls & Monitoring ═══════════ -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ── Control Buttons ── -->
            <Border Grid.Row="0" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Playback Control" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,3" />
                    <TextBlock Text="Play any audio on your system, then click Start Sync"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,12"
                               HorizontalAlignment="Center" />

                    <WrapPanel HorizontalAlignment="Center">
                        <Button Content="Start Sync" Command="{Binding StartSyncCommand}"
                                Style="{StaticResource SyncButton}" Margin="6"
                                Background="#111111" Foreground="#5A9A5A" />
                        <Button Content="Stop Sync" Command="{Binding StopSyncCommand}"
                                Style="{StaticResource SyncButton}" Margin="6"
                                Background="#111111" Foreground="#B05050" />
                    </WrapPanel>

                    <!-- Error / info message -->
                    <Border CornerRadius="6" Margin="0,10,0,0" Padding="12,8"
                            Background="#0D0808"
                            BorderThickness="1" BorderBrush="#1E1414"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisConverter}, FallbackValue=Collapsed}">
                        <TextBlock Text="{Binding ErrorMessage}" 
                                   Foreground="{StaticResource AccentRedBrush}"
                                   FontSize="11" TextWrapping="Wrap" FontWeight="Medium"
                                   HorizontalAlignment="Center" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── Master Delay ── -->
            <Border Grid.Row="1" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Master Delay Offset" FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8" />
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Right" Width="55" TextAlignment="Right" 
                                   VerticalAlignment="Center" FontSize="12" FontWeight="Medium"
                                   Foreground="{StaticResource AccentPrimaryBrush}">
                            <Run Text="{Binding MasterDelayOffset, StringFormat='{}{0:F0}', Mode=OneWay}" />
                            <Run Text="ms" />
                        </TextBlock>
                        <Slider Value="{Binding MasterDelayOffset}" Maximum="500" Minimum="0"
                                Style="{StaticResource ModernSlider}" />
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- ── Waveform Visualization ── -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Text="Waveform" FontSize="12" FontWeight="Medium"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <!-- Audio level indicator -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="Level " FontSize="9" Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                            <Border CornerRadius="2" Background="#111111" Height="6" Width="70"
                                    VerticalAlignment="Center">
                                <Border CornerRadius="2" HorizontalAlignment="Left"
                                        Width="{Binding AudioLevel, Converter={StaticResource LevelToWidthConverter}, FallbackValue=0}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#505050" Offset="0" />
                                            <GradientStop Color="#808080" Offset="0.7" />
                                            <GradientStop Color="#B05050" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Border>
                        </StackPanel>
                    </DockPanel>

                    <Border CornerRadius="8" Background="#060606" Padding="4" ClipToBounds="True"
                            BorderThickness="1" BorderBrush="#111111">
                        <Canvas x:Name="WaveformCanvas" SizeChanged="WaveformCanvas_SizeChanged" />
                    </Border>
                </DockPanel>
            </Border>

            <!-- ── Monitoring Stats ── -->
            <Border Grid.Row="3" Style="{StaticResource CardBorder}">
                <UniformGrid Columns="3">
                    <!-- Active Devices -->
                    <StackPanel HorizontalAlignment="Center" Margin="8,0">
                        <TextBlock Text="Active Devices" FontSize="9" 
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding ActiveDeviceCount}" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                    <!-- Max Latency Diff -->
                    <StackPanel HorizontalAlignment="Center" Margin="8,0">
                        <TextBlock Text="Max Latency Diff" FontSize="9"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                        <TextBlock FontSize="28" FontWeight="SemiBold" HorizontalAlignment="Center"
                                   Foreground="{StaticResource TextPrimaryBrush}">
                            <Run Text="{Binding MaxLatencyDiff, StringFormat='{}{0:F1}', Mode=OneWay}" />
                            <Run Text="ms" FontSize="13" />
                        </TextBlock>
                    </StackPanel>
                    <!-- Status -->
                    <StackPanel HorizontalAlignment="Center" Margin="8,0">
                        <TextBlock Text="Status" FontSize="9"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding PlaybackStatus}" FontSize="20" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="{Binding StatusBrush}" />
                    </StackPanel>
                </UniformGrid>
            </Border>
        </Grid>

        <!-- ═══════════ FOOTER ═══════════ -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Margin="0,8,0,0" Padding="10,5">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" Text="v1.1.0" FontSize="9"
                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Opacity="0.5" />
                <TextBlock FontSize="9" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                           Opacity="0.5">
                    <Run Text="SyncWave" FontWeight="Medium" />
                    <Run Text=" — System audio routed via WASAPI loopback. No kernel drivers required." />
                </TextBlock>
            </DockPanel>
        </Border>
    </Grid>
    </Grid>
    </Border>
</Window>
