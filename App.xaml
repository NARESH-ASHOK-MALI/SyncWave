<Application x:Class="SyncWave.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <!-- Global Dark Theme Overrides -->

        <!-- Window / Control Foreground -->
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#D4D4D4" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#D4D4D4" />

        <!-- ScrollBar Styling -->
        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <!--
            IMPORTANT: Do NOT use an implicit TextBlock style here!
            Implicit TextBlock styles in Application.Resources break the visual tree
            of ALL templated controls (Button, CheckBox, etc.) because TextBlock
            is used inside their control templates. This is a well-known WPF issue.
            Instead, set Foreground on the Window itself or use explicit x:Key styles.
        -->

        <!-- ToolTip dark theme -->
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#111111" />
            <Setter Property="Foreground" Value="#D4D4D4" />
            <Setter Property="BorderBrush" Value="#1E1E1E" />
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI" />
        </Style>
    </Application.Resources>
</Application>
