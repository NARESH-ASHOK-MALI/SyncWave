<Application x:Class="SyncWave.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <!-- Global Dark Theme Overrides -->

        <!-- Window / Control Foreground -->
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#E0E0E0" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#E0E0E0" />

        <!-- ScrollBar Styling -->
        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <!--
            IMPORTANT: Do NOT use an implicit TextBlock style here!
            Implicit TextBlock styles in Application.Resources break the visual tree
            of ALL templated controls (Button, CheckBox, etc.) because TextBlock
            is used inside their control templates. This is a well-known WPF issue.
            Instead, set Foreground on the Window itself or use explicit x:Key styles.
        -->

        <!-- CheckBox styling for dark theme -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E0E0E0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <!-- ToolTip dark theme -->
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#1A1A2E" />
            <Setter Property="Foreground" Value="#E0E0E0" />
            <Setter Property="BorderBrush" Value="#0F3460" />
        </Style>
    </Application.Resources>
</Application>
